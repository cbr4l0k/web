---
import { getCollection, render } from "astro:content";
import StandardPageLayout from "../../layouts/StandardPageLayout.astro";
import TableOfContents from "../../components/TableOfContents.astro";

export async function getStaticPaths() {
  const randomPosts = await getCollection("random");
  return randomPosts
  	.filter(itme => !itme.data.private)
  	.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<StandardPageLayout title={post.data.title}>
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2 text-[#222]">{post.data.title}</h1>
    <p class="text-gray-600 mb-2">{post.data.summary}</p>
    {post.data.author && (
      <p class="text-sm text-gray-500">by {post.data.author}</p>
    )}
    {post.data.date && (
      <p class="text-sm text-gray-500">{post.data.date}</p>
    )}
  </div>
  
  <article class="random-content grid gap-4 md:grid-cols-1">
    <TableOfContents headings={headings} />
    <Content />
  </article>
</StandardPageLayout>
