---
import StandardPageLayout from "../../layouts/StandardPageLayout.astro";
import ReferenceCard from "../../components/ReferenceCard.astro";
import { references } from "../../data/references";
import { groupReferencesByCategory } from "../../utils/references.js";

const groupedReferences = groupReferencesByCategory(references);

const formatCount = (count: number) => `${count} ${count === 1 ? "entry" : "entries"}`;
---
<StandardPageLayout title="Library">
<p class="mb-8 max-w-3xl opacity-80">
  Fragments, tools, papers, and strange corners of the internet I want close while studying different things.
  This is the shelf where they live now.
</p>

<nav aria-label="Library categories" class="mb-12">
  <ul class="flex flex-wrap gap-2">
    {groupedReferences.map((group) => (
      <li>
        <a
          href={`#${group.anchor}`}
          class="surface-label px-3 py-1.5 text-xs font-semibold text-[#222] transition-colors hover:bg-gray-50 sm:text-[0.8rem]"
        >
          <span>{group.title}</span>
          <span class="opacity-60">{group.references.length}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<div class="space-y-12">
  {groupedReferences.map((group) => (
    <section id={group.anchor} class="scroll-mt-8">
      <div class="mb-4 flex items-end justify-between gap-3 border-b border-gray-200 pb-2">
        <h2 class="mb-0 text-xl font-semibold sm:text-lg">{group.title}</h2>
        <p class="mb-0 text-xs opacity-60">{formatCount(group.references.length)}</p>
      </div>

      <ul class="grid gap-3 sm:grid-cols-1">
        {group.references.map((reference) => (
          <ReferenceCard reference={reference} />
        ))}
      </ul>
    </section>
  ))}
</div>
</StandardPageLayout>
