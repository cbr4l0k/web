---
export interface Props {
  href: string;
  title: string;
  status?: string;
  summary?: string;
  metadata?: Array<{ label: string; value: string }>;
}

const { href, title, status, summary, metadata = [] } = Astro.props;
---
<li class="content-surface content-surface--interactive p-4">
  <a href={href} class="no-underline">
    <div class="mb-2 flex items-center justify-between">
      <h4 class="text-lg font-semibold text-[#222]">{title}</h4>
      {status && (
        <span class="surface-label px-2 py-0.5 text-[10px] font-semibold">
          {status}
        </span>
      )}
    </div>
    {metadata.map(({ label, value }) => (
      <p class="text-xs opacity-70 mb-1">{label}: {value}</p>
    ))}
    {summary && <p class="text-sm opacity-90">{summary}</p>}
    <slot />
  </a>
</li>
