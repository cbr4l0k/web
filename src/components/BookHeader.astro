---
export interface Props {
  title: string;
  summary?: string;
  author?: string;
  status?: string;
  started?: string;
  finished?: string;
}
const { title, summary, author, status, started, finished } = Astro.props as Props;
---
<header>
  <h1 class="mb-4 text-3xl font-extrabold tracking-tight text-[#222]">{title}</h1>
  {summary && <p class="mb-6 leading-relaxed">{summary}</p>}
  <div class="mb-6 flex flex-wrap items-center gap-3">
    {status && (
      <span class="surface-label px-3 py-1 text-xs font-semibold">{status}</span>
    )}
    {author && <span class="text-xs opacity-70">Author: {author}</span>}
    {started && <span class="text-xs opacity-70">Date started: {started}</span>}
    {finished && <span class="text-xs opacity-70">Date finished: {finished}</span>}
  </div>
</header>
