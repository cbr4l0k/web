---
import { createPath } from "../utils/paths";

export interface Props {
  title: string;
  type: "entry" | "fact";
  summary?: string;
  image?: string;
  imageAlt?: string;
  Content: any;
}

const { title, type, summary, image, imageAlt, Content } = Astro.props as Props;
const imageSrc = image ? createPath(`/assets/projects/${image}`) : undefined;
---

{type === "fact" ? (
  <section class="mx-auto max-w-3xl px-3 py-6 text-center">
    <blockquote class="border border-black/10 bg-white/70 px-5 py-6 text-2xl leading-relaxed font-semibold italic text-[#222]">
      <Content />
    </blockquote>
  </section>
) : (
  <section class="grid gap-5 border border-black/10 bg-white/80 p-6 md:grid-cols-[220px_minmax(0,1fr)] md:items-start">
    {imageSrc && (
      <div class="md:sticky md:top-6">
        <img
          src={imageSrc}
          alt={imageAlt ?? title}
          class="h-48 w-full border border-black/10 object-cover md:h-[220px] md:w-[220px]"
        />
      </div>
    )}
    <div class="grid gap-4">
      <header class="grid gap-2">
        <h2 class="text-2xl font-extrabold tracking-tight text-[#222]">{title}</h2>
        {summary && <p class="max-w-2xl leading-relaxed text-black/70">{summary}</p>}
      </header>
      <div class="grid gap-4">
        <Content />
      </div>
    </div>
  </section>
)}
